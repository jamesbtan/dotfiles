Print
	scrot "$HOME/Pictures/screenshot/$(date +%F-%H%M%S-%N)_screenshot.png"
ctrl + Print
	scrot -s -d 0.1 -F "$HOME/Pictures/screenshot/$(date +%F-%H%M%S-%N)_screenshot.png"
shift + Print
	scrot -u "$HOME/Pictures/screenshot/$(date +%F-%H%M%S-%N)_screenshot.png"
shift + XF86MonBrightnessDown
	xbacklight -dec 1
shift + XF86MonBrightnessUp
	xbacklight -inc 1
XF86MonBrightnessDown
	xbacklight -dec 5
XF86MonBrightnessUp
	xbacklight -inc 5
XF86AudioRaiseVolume
	amixer sset 'Master' 1%+
XF86AudioLowerVolume
	amixer sset 'Master' 1%-
XF86AudioMute
	amixer sset 'Master' toggle
ctrl + alt + Delete
	pkill Xorg
super + shift + r
